# Files and directories useful for development but excluded from the
# CRAN tarball. Uses Perl-compatible regular expressions.

# Package sticker
^dplR_Sticker\.png$

# README source and rendered file
^README\.Rmd$
^README\.md$

# RStudio project files
^.*\.Rproj$
^\.Rproj\.user$

# Local R build configuration (Makevars, build.Renviron, check.Renviron)
^\.R$

# GitHub Actions workflows
^\.github$

# IDE-specific directories
^\.positai$
^\.claude$

# Developer docs and release checklist
^00_README-developer$
^00_CRAN-release$

# Reverse dependency check directory (created by revdepcheck package)
^revdep$

# R CMD check artifact
^dplR-Ex\.R$

# LaTeX and knitr vignette build artifacts (relevant if building vignettes locally)
^vignettes/Rplots.*\.pdf$
^inst/doc/cache(/.*)?$
^inst/doc/figure(/.*)?$
^inst/doc/.*\.(Rnw|Rout|aux|bbl|blg|fdb_latexmk|fls|glo|gls|glg|idx|ind|ilg|lof|log|lot|out|synctex\.gz|tex|toc)$
^.*-tikzDictionary$
^.*/auto$
